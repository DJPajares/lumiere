{
  "name": "lumiere",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:invite": "pnpm --filter @lumiere/invite dev",
    "dev:dashboard": "pnpm --filter @lumiere/dashboard dev",
    "dev:api": "pnpm --filter @lumiere/api dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint-staged": "lint-staged",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "check:dashboard-ui-boundary": "node scripts/check-dashboard-ui-boundary.mjs",
    "check:theme-boundaries": "node scripts/check-theme-boundaries.mjs",
    "check:theme-contracts": "pnpm --filter @lumiere/themes test",
    "check:follow-up-regression": "pnpm check:next-image-usage && pnpm check:theme-boundaries && pnpm test",
    "db:generate": "pnpm --filter @lumiere/db db:generate",
    "db:migrate": "pnpm --filter @lumiere/db db:migrate",
    "db:seed": "pnpm --filter @lumiere/api exec node --import tsx ../../packages/db/src/seed.ts",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:studio": "pnpm --filter @lumiere/db db:studio",
    "format": "prettier --write --ignore-unknown \"**/*.{json,yml,yaml,mjs,ts,tsx}\"",
    "format:check": "prettier --check --ignore-unknown \"**/*.{json,yml,yaml,mjs,ts,tsx}\"",
    "check:next-image-usage": "node scripts/check-next-image-usage.mjs"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}

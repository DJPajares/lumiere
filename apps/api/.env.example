NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lumiere
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_JWT_SECRET=replace-with-jwt-secret
# Optional: JSON from /auth/v1/.well-known/jwks.json to avoid remote JWKS fetches locally.
# Run: curl -fsS https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS=
INVITE_TOKEN_SECRET=replace-with-random-secret
PUBLIC_APP_BASE_URL=http://localhost:3000
DASHBOARD_APP_BASE_URL=http://localhost:3001

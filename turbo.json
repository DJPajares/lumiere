{
  "$schema": "https://v2-10-5.turborepo.dev/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "@lumiere/api#build": {
      "dependsOn": ["^build"],
      "outputs": [],
      "env": [
        "DASHBOARD_APP_BASE_URL",
        "INVITE_TOKEN_SECRET",
        "NODE_ENV",
        "DATABASE_URL",
        "SUPABASE_URL",
        "SUPABASE_SERVICE_ROLE_KEY",
        "SUPABASE_JWT_SECRET",
        "SUPABASE_JWKS",
        "PUBLIC_APP_BASE_URL",
        "PORT"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    }
  }
}

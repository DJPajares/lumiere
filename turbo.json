{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@lumiere/api#build": {
      "dependsOn": ["^build"],
      "outputs": [],
      "env": [
        "NODE_ENV",
        "DATABASE_URL",
        "SUPABASE_URL",
        "PUBLIC_APP_BASE_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    }
  }
}